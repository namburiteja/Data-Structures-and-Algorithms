class SinglyLinkedList {

    // Node class
    class Node{
        int data;
        Node next;
        Node(int data){
            this.data = data;
            this.next = next;
        }
    }
    Node head;
    public void insertAtBeginning(int val){
        Node newVal = new Node(val);
        newVal.next = head;
        head = newVal;
    }
    public void insertAtEnd(int val){
        Node newNode = new Node(val);
        if(head==null){
            head=newNode;
            newNode.next = null;
            return;
        }
        if(head.next==null){
            head.next = newNode;
            newNode.next = null;
            return;
        }
        Node temp = head;
        while(temp.next!=null){
            temp = temp.next;
        }
        temp.next = newNode;
        newNode.next = null;
    }
    public void display(){
        if(head==null){
            System.out.println("List is Empty");
            return;
        }
        Node temp = head;
        while(temp!=null){
            System.out.print(temp.data+" -> ");
            temp = temp.next;
        }
        System.out.print("null");
        System.out.println();
    }
    public void search(int val){
        if(head==null) System.out.println("List is Empty");
        Node temp = head;
        int pos = 1;
        while(temp!=null){
            if(temp.data==val){
                System.out.println("Element found at position "+pos);
                return;
            }
            pos+=1;
            temp = temp.next;
        }
        if(temp==null) System.out.println("There is no "+val+" in this list");
    }
    public void deleteFromBeginning(){
        if(head==null){
            System.out.println("There is no elemet to delete");
            return;
        }
        head = head.next;
    }
    public void deleteFromEnd(){
        if(head==null){
            System.out.println("There is no elemet to delete");
            return;
        }
        Node temp = head;
        while(temp.next.next!=null){
            temp = temp.next;
        }
        temp.next = temp.next.next;
    }

    // Main Method
    public static void main(String[] args) {
        SinglyLinkedList list = new SinglyLinkedList();

        list.insertAtBeginning(20);
        list.insertAtBeginning(10);
        list.insertAtEnd(30);
        list.insertAtEnd(40);

        list.display();

        list.search(30);

        list.deleteFromBeginning();
        list.display();

        list.deleteFromEnd();
        list.display();
    }
}
