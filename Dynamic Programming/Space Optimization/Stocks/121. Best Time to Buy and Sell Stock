class Solution {
    public int maxProfit(int[] arr) {
        int maxi = 0;
        int low = arr[0];
        for(int i=1;i<arr.length;i++){
            if(arr[i]<low){
                low = arr[i];
                continue;
            }
            maxi = Math.max(arr[i]-low,maxi);
        }
        return maxi;
    }
}
TIME COMPLEXITY - O(n)
SPACE COMPLEXITY - O(1)
