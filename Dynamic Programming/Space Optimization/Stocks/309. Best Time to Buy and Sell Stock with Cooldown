class Solution {
    public int maxProfit(int[] prices) {
        int n = prices.length;
        int[] dp = new int[2];
        int[] last = new int[2];
        for(int i=n-1;i>=0;i--){
            int[] temp = new int[2];
            temp[1] = Math.max(-prices[i]+dp[0],dp[1]);
            temp[0] = Math.max(prices[i]+last[1],dp[0]);
            last = dp;
            dp = temp;
        }
        return dp[1];
    }
}
TIME COMPLEXITY - O(n)
SPACE COMPLEXITY - O(2)
