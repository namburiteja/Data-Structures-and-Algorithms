class Solution {
    public int maxProfit(int[] prices) {
        int n = prices.length;
        int[][] dp = new int[2][4+1];
        for(int i=n-1;i>=0;i--){
            int[][] temp = new int[2][4+1];
            for(int k=3;k>=0;k--){
                temp[1][k] = Math.max(-prices[i]+dp[0][k+1],dp[1][k]);
                temp[0][k] = Math.max(prices[i]+dp[1][k+1],dp[0][k]);
            }
            dp = temp;
        }
        return dp[1][0];
    }
}
TIME COMPLEXITY - O(n*2*4)
SPACE COMPLEXITY - O(2*4)
