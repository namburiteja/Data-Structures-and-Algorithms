class Solution {
    public int longestCommonSubsequence(String text1, String text2) {
        int n1 = text1.length();
        int n2 = text2.length();
        int[] dp = new int[n2+1];
        for(int i=1;i<=n1;i++){
            int[] prev = new int[n2+1];
            for(int j=1;j<=n2;j++){
                if(text1.charAt(i-1)==text2.charAt(j-1)) prev[j] = 1 + dp[j-1];
                else prev[j] = Math.max(dp[j],prev[j-1]);
            }
            dp = prev;
        }
        return dp[n2];
    }
}
TIME COMPLEXITY - O(n1*n2)
SPACE COMPLEXITY - O(n2)
