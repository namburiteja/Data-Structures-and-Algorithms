class Solution {
    public int minDistance(String word1, String word2) {
        int n1 = word1.length();
        int n2 = word2.length();
        int[] dp = new int[n2+1];
        for(int i=1;i<=n1;i++){
            int[] temp = new int[n2+1];
            for(int j=1;j<=n2;j++){
                if(word1.charAt(i-1)==word2.charAt(j-1)) temp[j] = 1 + dp[j-1];
                else temp[j] = Math.max(dp[j],temp[j-1]);
            }
            dp = temp;
        }        
        int lcs = dp[n2];
        int deletions = n1 - lcs + n2 - lcs;
        return deletions;
    }
}
TIME COMPLEXITY - O(n1*n2)
SPACE COMPLEXITY - O(n2)
