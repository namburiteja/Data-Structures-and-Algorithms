class Solution {
    private int lcs(String s1,String s2,int i1,int i2,int[][] dp){
        if(i1<0 ||i2<0) return 0;
        if(dp[i1][i2]!=-1) return dp[i1][i2];
        if(s1.charAt(i1)==s2.charAt(i2)) return dp[i1][i2] = 1 + lcs(s1,s2,i1-1,i2-1,dp);
        else{
            return dp[i1][i2] = Math.max(lcs(s1,s2,i1-1,i2,dp),lcs(s1,s2,i1,i2-1,dp));
        }
    }
    public int minInsertions(String s) {
        int n = s.length();
        StringBuilder sb = new StringBuilder(s);
        String s2 = sb.reverse().toString();
        int[][] dp = new int[n][n];
        for(int i=0;i<n;i++) for(int j=0;j<n;j++) dp[i][j] = -1;
        return n-lcs(s,s2,n-1,n-1,dp);
    }
}
TIME COMPLEXITY - O(n*n)+O(n+n)
SPACE COMPLEXITY - O(n*n)
