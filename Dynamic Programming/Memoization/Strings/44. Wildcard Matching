class Solution {
    private boolean card(String s,int i,String p,int j,int[][] dp){
        if(i<0 && j<0) return true;
        if(j<0 && i>=0) return false;
        if(i<0){
            for(int k=0;k<=j;k++){
                if(p.charAt(k)!='*') return false;
            }
            return true;
        }
        if(dp[i][j]!=-1) return dp[i][j]==1 ? true : false;
        if(s.charAt(i)==p.charAt(j)) return (dp[i][j] = card(s,i-1,p,j-1,dp) ? 1 : 0)==1 ? true : false;
        else if(p.charAt(j)=='?') return (dp[i][j] = card(s,i-1,p,j-1,dp) ? 1 : 0)==1 ? true : false;
        else if(p.charAt(j)=='*'){
            if(j-1==-1) return true;
            return (dp[i][j] = (card(s,i-1,p,j,dp) || card(s,i,p,j-1,dp)) ? 1 : 0)==1 ? true : false;
        }
        return false;
    }
    public boolean isMatch(String s, String p) {
        int m = s.length();
        int n = p.length();
        int[][] dp = new int[m][n];
        for(int i=0;i<m;i++) for(int j=0;j<n;j++) dp[i][j] = -1;
        return card(s,m-1,p,n-1,dp) ? true : false;
    }
}
TIME COMPLEXITY - O(m*n)
SPACE COMPLEXITY - O(m*n)+O(m+n)
