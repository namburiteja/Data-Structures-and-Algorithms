class Solution {
    private int editDistance(String s1,int i,String s2,int j,int[][] dp){
        if(i<0) return j+1;
        if(j<0) return i+1;
        if(dp[i][j]!=-1) return dp[i][j];
        if(s1.charAt(i)==s2.charAt(j)) return dp[i][j] = editDistance(s1,i-1,s2,j-1,dp);
        else{
            int insert = 1 + editDistance(s1,i,s2,j-1,dp);
            int delete = 1 + editDistance(s1,i-1,s2,j,dp);
            int replace = 1 + editDistance(s1,i-1,s2,j-1,dp);
            return dp[i][j] = Math.min(insert,Math.min(delete,replace));
        }
    }
    public int minDistance(String word1, String word2) {
        int m = word1.length();
        int n = word2.length();
        int[][] dp = new int[m][n];
        for(int i=0;i<m;i++) for(int j=0;j<n;j++) dp[i][j] = -1;
        return editDistance(word1,m-1,word2,n-1,dp);
    }
}
TIME COMPLEXITY - O(m*n)
SPACE COMPLEXITY - O(m*n)+O(m+n)
