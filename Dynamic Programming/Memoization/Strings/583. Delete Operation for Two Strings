class Solution {
    private int longestCommonSubsequence(String s1,String s2,int i1,int i2,int[][] dp){
        if(i1<0 || i2<0) return 0;
        if(dp[i1][i2]!=-1) return dp[i1][i2];
        if(s1.charAt(i1)==s2.charAt(i2)) return dp[i1][i2] = 1 + longestCommonSubsequence(s1,s2,i1-1,i2-1,dp);
        else return dp[i1][i2] = Math.max(longestCommonSubsequence(s1,s2,i1-1,i2,dp),longestCommonSubsequence(s1,s2,i1,i2-1,dp));
    }
    public int minDistance(String word1, String word2) {
        int n1 = word1.length();
        int n2 = word2.length();
        int[][] dp = new int[n1][n2];
        for(int i=0;i<n1;i++) for(int j=0;j<n2;j++) dp[i][j] = -1;
        int lcs = longestCommonSubsequence(word1,word2,n1-1,n2-1,dp);
        int deletions = n1 - lcs + n2 - lcs;
        return deletions;
    }
}
TIME COMPLEXITY - O(n1*n2)+O(n1+n2)
SPACE COMPLEXITY - O(n1+n2)
