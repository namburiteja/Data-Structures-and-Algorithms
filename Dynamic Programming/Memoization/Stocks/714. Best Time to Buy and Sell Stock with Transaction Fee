class Solution {
    private int bttbass(int[] prices,int i,int n,int fee,int flag,int[][] dp){
        if(i>=n) return 0;
        if(dp[i][flag]!=-1) return dp[i][flag];
        if(flag==1){
            int buy = -prices[i] + bttbass(prices,i+1,n,fee,0,dp);
            int notbuy = bttbass(prices,i+1,n,fee,1,dp);
            return dp[i][flag] = Math.max(buy,notbuy);
        }else{
            int sell = prices[i] - fee + bttbass(prices,i+1,n,fee,1,dp);
            int notsell = bttbass(prices,i+1,n,fee,0,dp);
            return dp[i][flag] = Math.max(sell,notsell);
        }
    }
    public int maxProfit(int[] prices, int fee) {
        int n = prices.length;
        int dp[][] = new int[n][2];
        for(int i=0;i<n;i++){
            dp[i][1] = -1;
            dp[i][0] = -1;
        }
        return bttbass(prices,0,n,fee,1,dp);
    }
}
TIME COMPLEXITY - O(n*2)
SPACE COMPLEXITY - O(n*2)+O(n+2)
