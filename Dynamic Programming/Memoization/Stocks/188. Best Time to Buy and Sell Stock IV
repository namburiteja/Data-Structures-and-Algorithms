class Solution {
    private int bttbass(int[] prices,int i,int flag,int cnt,int k,int n,int[][][] dp){
        if(i==n) return 0;
        if(cnt>=k) return 0;
        if(dp[i][flag][cnt]!=-1) return dp[i][flag][cnt];
        if(flag==1){
            int buy = -prices[i] + bttbass(prices,i+1,0,cnt+1,k,n,dp);
            int notbuy = bttbass(prices,i+1,1,cnt,k,n,dp);
            return dp[i][flag][cnt] = Math.max(buy,notbuy);
        }else{
            int sell = prices[i] + bttbass(prices,i+1,1,cnt+1,k,n,dp);
            int notsell = bttbass(prices,i+1,0,cnt,k,n,dp);
            return dp[i][flag][cnt] = Math.max(sell,notsell);
        }
    }
    public int maxProfit(int k, int[] prices) {
        int n = prices.length;
        int[][][] dp = new int[n][2][k+k];
        for(int i=0;i<n;i++) for(int j=0;j<2;j++) for(int kk=0;kk<k+k;kk++) dp[i][j][kk] = -1;
        return bttbass(prices,0,1,0,k+k,n,dp);
    }
}
TIME COMPLEXITY - O(n*2*k)
SPACE COMPLEXITY - O(n*2*k)+O(n+2+k)
