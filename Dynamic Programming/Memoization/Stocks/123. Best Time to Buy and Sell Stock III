class Solution {
    private int bttbass(int[] prices,int i,int flag,int cnt,int[][][] dp){
        if(i==prices.length) return 0;
        if(cnt>=4) return 0;
        if(dp[i][flag][cnt]!=-1) return dp[i][flag][cnt];
        if(flag==1){
            int buy = -prices[i] + bttbass(prices,i+1,0,cnt+1,dp);
            int notbuy = bttbass(prices,i+1,1,cnt,dp); 
            return dp[i][flag][cnt] = Math.max(buy,notbuy);
        }else{
            int sell = prices[i] + bttbass(prices,i+1,1,cnt+1,dp);
            int notsell = bttbass(prices,i+1,0,cnt,dp);
            return dp[i][flag][cnt] = Math.max(sell,notsell);
        }
    }                                                                                                                        public int maxProfit(int[] prices) {
        int n = prices.length;
        int[][][] dp = new int[n][2][4];
        for(int i=0;i<n;i++) for(int j=0;j<2;j++) for(int k=0;k<4;k++) dp[i][j][k] = -1;
        return bttbass(prices,0,1,0,dp);
    }
}
TIME COMPLEXITY - O(n*2*4)
SPACE COMPLEXITY - O(n*2*4)+O(n+2+4)
