class Solution {
    private int bttbass(int[] prices,int i,int flag,int[][] dp){
        if(i==prices.length) return 0;
        if(dp[i][flag]!=-1) return dp[i][flag];
        int profit = 0;
        if(flag==1){
            dp[i][flag] = Math.max(-prices[i]+bttbass(prices,i+1,0,dp),bttbass(prices,i+1,1,dp));
        }else{
            dp[i][flag] = Math.max(prices[i]+bttbass(prices,i+1,1,dp),bttbass(prices,i+1,0,dp));
        }
        return dp[i][flag];
    }
    public int maxProfit(int[] prices) {
        int n = prices.length;
        int[][] dp = new int[n][2];
        for(int i=0;i<n;i++){
            dp[i][0] = -1;
            dp[i][1] = -1;
        }
        return bttbass(prices,0,1,dp);
    }
}
TIME COMPLEXITY - O(n*2)
SPACE COMPLEXITY - O(n*2)
