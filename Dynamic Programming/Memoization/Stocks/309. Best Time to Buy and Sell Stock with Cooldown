class Solution {
    private int bttbass(int[] prices,int i,int flag,int n,int[][] dp){
        if(i>=n) return 0;
        if(dp[i][flag]!=-1) return dp[i][flag];
        if(flag==1){
            int buy = -prices[i] + bttbass(prices,i+1,0,n,dp);
            int notbuy = bttbass(prices,i+1,1,n,dp);
            return dp[i][flag] = Math.max(buy,notbuy);
        }else{
            int sell = prices[i] + bttbass(prices,i+2,1,n,dp);
            int notsell = bttbass(prices,i+1,0,n,dp);
            return dp[i][flag] = Math.max(sell,notsell);
        }
    }
    public int maxProfit(int[] prices) {
        int n = prices.length;
        int[][] dp = new int[n][2];
        for(int i=0;i<n;i++){
            dp[i][0] = -1;
            dp[i][1] = -1;
        }
        return bttbass(prices,0,1,n,dp);
    }
}
TIME COMPLEXITY - O(n*2)
SPACE COMPLEXITY - O(n*2)+O(n+2)
