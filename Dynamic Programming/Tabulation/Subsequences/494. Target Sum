class Solution {
    public int findTargetSumWays(int[] nums, int target) {
        int n = nums.length;
        int total = Arrays.stream(nums).sum();
        int x = total-target;
        if(x<0 || x%2!=0) return 0;
        int actualTarget = x/2;
        int[][] dp = new int[n][actualTarget+1];
        if(nums[0]==0) dp[0][0] = 2;
        else dp[0][0] = 1;
        if(nums[0]!=0 && nums[0]<=actualTarget) dp[0][nums[0]]= 1;
        for(int i=1;i<n;i++){
            for(int tar=0;tar<=actualTarget;tar++){
                int nottake = dp[i-1][tar];
                int take = 0;
                if(nums[i]<=tar) take = dp[i-1][tar-nums[i]];
                dp[i][tar] = take+nottake;
            }
        }
        return dp[n-1][actualTarget];
    }
}
TIME COMPLEXITY - O(n*actualTarget)
SPACE COMPLEXITY - O(n*actualTarget)
