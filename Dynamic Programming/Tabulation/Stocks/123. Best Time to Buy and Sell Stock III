class Solution {
    public int maxProfit(int[] prices) {
        int n = prices.length;
        int[][][] dp = new int[n+1][2][4+1];
        for(int i=n-1;i>=0;i--){
            for(int k=3;k>=0;k--){
                dp[i][1][k] = Math.max(-prices[i]+dp[i+1][0][k+1],dp[i+1][1][k]);
                dp[i][0][k] = Math.max(prices[i]+dp[i+1][1][k+1],dp[i+1][0][k]);
            }
        }
        return dp[0][1][0];
    }
}
TIME COMPLEXITY - O(n*2*4)
SPACE COMPLEXITY - O(n*2*4)
