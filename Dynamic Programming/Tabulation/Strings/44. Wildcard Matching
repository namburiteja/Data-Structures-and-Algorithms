class Solution {
    public boolean isMatch(String s, String p) {
        int m = s.length();
        int n = p.length();
        int[][] dp = new int[m+1][n+1];
        dp[0][0] = 1;
        for(int i=1;i<=m;i++) dp[i][0] = 0;
        for(int j=1;j<=n;j++){
            dp[0][j] = ((dp[0][j-1]==1 ? true : false) && (p.charAt(j-1) == '*')) ? 1 : 0;
        }
        for(int i=1;i<=m;i++){
            for(int j=1;j<=n;j++){
                if(s.charAt(i-1)==p.charAt(j-1) || p.charAt(j-1)=='?') dp[i][j] = dp[i-1][j-1];
                else if(p.charAt(j-1)=='*') dp[i][j] = ((dp[i-1][j]==1 ? true : false) || (dp[i][j-1]==1 ? true : false)) ? 1 : 0;
                else dp[i][j] = 0;
            }
        }
        return dp[m][n]==1 ? true : false;
    }
}
TIME COMPLEXITY - O(m*m)
SPACE COMPLEXITY - O(m*n)
