class Solution {
    private int coinChange(int i,int target,int[] arr){
        if(i==0){
            if(target%arr[i]==0) return 1;
            return 0;
        }
        int nottake = coinChange(i-1,target,arr);
        int take = 0;
        if(target>=arr[i]) take = coinChange(i,target-arr[i],arr);
        return take+nottake;
    }
    public int change(int amount, int[] coins) {
        int n = coins.length;
        return coinChange(n-1,amount,coins);
    }
}
TIME COMPLEXITY - > O(2**n)
SPACE COMPLEXITY - > O(n)
