class Solution {
    private int bttbass(int[] prices,int i,int flag,int cnt){
        if(i==prices.length) return 0;
        if(cnt>=4) return 0;
        if(flag==1){
            int buy = -prices[i] + bttbass(prices,i+1,0,cnt+1);
            int notbuy = bttbass(prices,i+1,1,cnt); 
            return Math.max(buy,notbuy);
        }else{
            int sell = prices[i] + bttbass(prices,i+1,1,cnt+1);
            int notsell = bttbass(prices,i+1,0,cnt);
            return Math.max(sell,notsell);
        }
    }
    public int maxProfit(int[] prices) {
        return bttbass(prices,0,1,0);
    }
}
TIME COMPLEXITY - O(2^(n*2*4))
SPACE COMPLEXITY - O(n)
