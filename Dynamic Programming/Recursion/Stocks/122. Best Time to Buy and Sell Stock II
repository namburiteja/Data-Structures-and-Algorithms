class Solution {
    private int bttbass(int[] prices,int i,int flag){
        if(i==prices.length) return 0;
        int profit = 0;
        if(flag==1){
            int buy = -prices[i] + bttbass(prices,i+1,0);
            int notbuy = bttbass(prices,i+1,1); 
            return Math.max(buy,notbuy);
        }else{
            int sell = prices[i] + bttbass(prices,i+1,1);
            int notsell = bttbass(prices,i+1,0);
            return Math.max(sell,notsell);
        }
    }
    public int maxProfit(int[] prices) {
        return bttbass(prices,0,1);
    }
}
TIME COMPLEXITY - O(2^(n+2))
SPACE COMPLEXITY - O(n)
