class Solution {
    private int bttbass(int[] prices,int i,int flag){
        if(i==prices.length) return 0;
        int profit = 0;
        if(flag==1){
            profit = Math.max(-prices[i]+bttbass(prices,i+1,0),bttbass(prices,i+1,1));
        }else{
            profit = Math.max(prices[i]+bttbass(prices,i+1,1),bttbass(prices,i+1,0));
        }
        return profit;
    }
    public int maxProfit(int[] prices) {
        return bttbass(prices,0,1);
    }
}
TIME COMPLEXITY - O(2^(n+2))
SPACE COMPLEXITY - O(n)
