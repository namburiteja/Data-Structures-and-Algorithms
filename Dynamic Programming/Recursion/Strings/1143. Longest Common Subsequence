class Solution {
    private int longestSequence(String text1,String text2,int i1,int i2){
        if(i1==-1 || i2==-1) return 0;
        if(text1.charAt(i1)==text2.charAt(i2)) return 1 + longestSequence(text1,text2,i1-1,i2-1);
        return Math.max(longestSequence(text1,text2,i1-1,i2),longestSequence(text1,text2,i1,i2-1));
    }
    public int longestCommonSubsequence(String text1, String text2) {
        int n1 = text1.length();
        int n2 = text2.length();
        return longestSequence(text1,text2,n1-1,n2-1);
    }
}
TIME COMPLEXITY - O(2**n1 + 2**n2)
SPACE COMPLEXITY - O(n)
