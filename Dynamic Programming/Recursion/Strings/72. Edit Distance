class Solution {
    private int editDistance(String s1,int i,String s2,int j){
        if(i<0) return j+1;
        if(j<0) return i+1;
        if(s1.charAt(i)==s2.charAt(j)) return editDistance(s1,i-1,s2,j-1);
        else{
            int insert = 1 + editDistance(s1,i,s2,j-1);
            int delete = 1 + editDistance(s1,i-1,s2,j);
            int replace = 1 + editDistance(s1,i-1,s2,j-1);
            return Math.min(insert,Math.min(delete,replace));
        }
    }
    public int minDistance(String word1, String word2) {
        int m = word1.length();
        int n = word2.length();
        return editDistance(word1,m-1,word2,n-1);
    }
}
TIME COMPLEXITY - O(3^(m+n))
SPACE COMPLEXITY - O(n+m)
