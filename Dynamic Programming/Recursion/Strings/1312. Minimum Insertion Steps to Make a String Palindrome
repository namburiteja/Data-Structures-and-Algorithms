class Solution {
    private int lcs(String s1,String s2,int i1,int i2){
        if(i1<0 ||i2<0) return 0;
        if(s1.charAt(i1)==s2.charAt(i2)) return 1 + lcs(s1,s2,i1-1,i2-1);
        else{
            return Math.max(lcs(s1,s2,i1-1,i2),lcs(s1,s2,i1,i2-1));
        }
    }
    public int minInsertions(String s) {
        int n = s.length();
        StringBuilder sb = new StringBuilder(s);
        String s2 = sb.reverse().toString();
        return n-lcs(s,s2,n-1,n-1);
    }
}
TIME COMPLEXITY - O(2**n1 + 2**n2)
SPACE COMPLEXITY - O(n1+n2)
